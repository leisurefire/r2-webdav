{
	"name": "r2-webdav-x",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "npm run dev -w @r2-webdav/dav-worker",
		"dev:web": "npm run dev -w @r2-webdav/web",
		"build": "npm run build --workspaces --if-present",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"deploy:worker": "npm run deploy -w @r2-webdav/dav-worker",
		"deploy:web": "npm run deploy -w @r2-webdav/web",
		"format": "prettier . --write",
		"format:check": "prettier . --check"
	},
	"devDependencies": {
		"prettier": "^3.1.1",
		"typescript": "^5.0.4"
	}
}
